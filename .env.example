# Optional: lock WeatherSpective to one location and hide location sidebar controls.
# Value must be valid JSON.
#
# Example:
# VITE_LOCKED_LOCATION={"name":"Bentonville","latitude":36.3729,"longitude":-94.2088,"country":"United States","admin1":"Arkansas"}

VITE_LOCKED_LOCATION=

# Optional: lock individual unit settings.
# Allowed values:
# - VITE_LOCKED_TEMPERATURE_UNIT: celsius | fahrenheit
# - VITE_LOCKED_WIND_SPEED_UNIT: kmh | mph | ms | kn
# - VITE_LOCKED_PRECIPITATION_UNIT: mm | inch

VITE_LOCKED_TEMPERATURE_UNIT=
VITE_LOCKED_WIND_SPEED_UNIT=
VITE_LOCKED_PRECIPITATION_UNIT=

# Optional: disable PWA generation and service worker output during build.
# Set to false for kiosk/browser-only deployments.

VITE_ENABLE_PWA=false
